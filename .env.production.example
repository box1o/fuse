# This file documents production configuration. Do not commit real secrets.
# Azure Container Apps supplies these values directly to the running container.

# Application
ENVIRONMENT=production
DEBUG=false
VERSION=1.0.0

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# Public URLs
FRONTEND_URL=https://app.teckstate.com
CORS_ALLOWED_ORIGINS=https://app.teckstate.com

# Azure Database for PostgreSQL
DATABASE_HOST=fuse.postgres.database.azure.com
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=fuse
DATABASE_PASSWORD=SET_IN_AZURE
DATABASE_SSLMODE=require
DATABASE_MIGRATE=true

# Redis
REDIS_HOST=SET_IN_AZURE
REDIS_PORT=SET_IN_AZURE
REDIS_USERNAME=SET_IN_AZURE
REDIS_PASSWORD=SET_IN_AZURE
REDIS_DB=0

# Authentication
AUTH_SESSION_SECRET=SET_IN_AZURE
AUTH_GOOGLE_CLIENT_ID=SET_IN_AZURE
AUTH_GOOGLE_CLIENT_SECRET=SET_IN_AZURE
AUTH_GOOGLE_CALLBACK_URL=https://mback.teckstate.com/auth/google/callback

# Session
SESSION_NAME=fuse_auth_session
SESSION_DURATION=86400
SESSION_COOKIE_PATH=/
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SAME_SITE=lax

# Mail
MAIL_FROM=SET_IN_AZURE
MAIL_NAME=Fuse
MAIL_PASSWORD=SET_IN_AZURE
